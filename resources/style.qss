    color: #cdd6f4;
}

/* Title Labels */
QLabel[class="title"] {
    font-size: 20pt;
    font-weight: bold;
    margin: 10px; /* SAME as light */
    color: #89b4fa;
}

/* General Labels */
QLabel {
    font-size: 11pt;
    color: #cdd6f4;
}

QLabel[class="bold"] {
    font-weight: bold;
    font-size: 13pt;
}

QLabel[class="help"] {
    color: #6c7086;
    font-size: 10pt;
    font-style: italic;
}

QLabel[class="total"] {
    font-weight: bold;
    font-size: 13pt;
}

QLabel[class="total-green"] {
    font-weight: bold;
    font-size: 13pt;
    color: #a6e3a1;
}

QLabel[class="total-red"] {
    font-weight: bold;
    font-size: 13pt;
    color: #f38ba8;
}

QLabel[class="code-prefix"] {
    font-weight: bold;
    font-size: 16pt;
    color: #89b4fa;
}

QLabel[class="code-letters"] {
    font-weight: bold;
    font-size: 16pt;
    color: #cdd6f4;
}


